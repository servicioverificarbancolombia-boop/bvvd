function fnValidacion($activo) {
	if ($activo.hasClass('paso-1')) {
		return true;
	}

	if ($activo.hasClass('paso-2')) {
		v1 = ($('.digitos-producto input').val().trim() != '');

		if (!v1) {
			$('.digitos-producto input').addClass('error').parent().find('p.error').html('El campo esta vacio');
		}
		return v1;
	}
	if ($activo.hasClass('paso-3')) {
		v1 = ($('.crear-clave input').val().trim() != '');
		v2 = ($('.repetir-clave input').val().trim() != '');

		if (!v1) {
			$('.crear-clave input').addClass('error').parent().find('p.error').html('El campo esta vacio');
		}
		if (!v2) {
			$('.repetir-clave input').addClass('error').parent().find('p.error').html('El campo esta vacio');
		}
		return v1 && v2;
	}
	if ($activo.hasClass('paso-4')) {
		v1 = ($('.codigo-confirmacion input').val().trim() != '');

		if (!v1) {
			$('.codigo-confirmacion input').addClass('error').parent().find('p.error').html('El campo esta vacio');
		}
		return v1;
	}
	return false;
}

function closeLogin() {
	var $login = $('div.panellogin');
	$login.slideUp('fast');
}

function closeMessajes(event) {
	(event.preventDefault) ? event.preventDefault() : event.returnValue = false;
	var $msjGral = $('div.div-mensajes-gral');
	$msjGral.slideUp();
}

function closeMessajesCodigo(event) {
	(event.preventDefault) ? event.preventDefault() : event.returnValue = false;
	var $msjGralCodigo = $('div.div-mensajes-gral-codigo');
	$msjGralCodigo.slideUp();
}

function aplicaEstiloValidacion(){
	var $messageNumeroDocumento=$('#formAutenticar\\:messageNumeroDocumento');
	var $messageClaveVirtual=$('#formAutenticar\\:messageClaveVirtual');
	var $messageOtp=$('#formAutenticar\\:messageOtp');

	var $panelClaveVirtual=$('#formAutenticar\\:panelClaveVirtual')
	var $panelOtp=$('#formAutenticar\\:panelOtp')

	var $pClavePersonal=$('#pClavePersonal');
	var $pToken=$('#pToken');

	var messagesNumeroDocumento=getMessages('NumeroDocumento'); 
	var hasMessagesNumeroDocumento=messagesNumeroDocumento.mensaje1!=null || messagesNumeroDocumento.mensaje2!=null;
	var messagesClaveVirtual=getMessages('ClaveVirtual'); 
	var hasMessagesClaveVirtual=messagesClaveVirtual.mensaje1!=null || messagesClaveVirtual.mensaje2!=null;
	var messagesOtp=getMessages('Otp'); 
	var hasMessagesOtp=messagesOtp.mensaje1!=null || messagesOtp.mensaje2!=null;

	var $decodedMessageNumeroDocumento=$('#formAutenticar\\:panelPublicMessageNumeroDocumento');
	var $decodedMessageClaveVirtual=$('#formAutenticar\\:panelPublicMessageClaveVirtual');
	var $decodedMessageOtp=$('#formAutenticar\\:panelPublicMessageOtp');

	if($messageNumeroDocumento!=null){
	   if($messageNumeroDocumento.text()!='' || ($panelClaveVirtual.length==0 && $panelOtp.length==0 && (hasMessagesNumeroDocumento || $decodedMessageNumeroDocumento.length!=0))){
		   $('.form-field__numero-documento input').addClass('error');
		   $('.error-message-container__numero-documento').addClass('show');
	   }else{
		   $('.form-field__numero-documento input').removeClass('error');
		   $('.error-message-container__numero-documento').removeClass('show');
	   }
	}
	
	if($messageClaveVirtual!=null){
	   if($messageClaveVirtual.text()!='' || ($panelOtp.length==0 && (hasMessagesClaveVirtual || $decodedMessageClaveVirtual.length!=0))){
		   $('.form-field__clave-virtual input').addClass('error');
		   $('.error-message-container__clave-virtual').addClass('show');
	   }else{
		   $('.form-field__clave-virtual input').removeClass('error');
		   $('.error-message-container__clave-virtual').removeClass('show');
	   }
	}
	
	if($messageOtp!=null){
	   if($messageOtp.text()!='' || hasMessagesOtp || $decodedMessageOtp.length!=0){
		   $('.form-field__otp input').addClass('error');
		   $('.error-message-container__otp').addClass('show');
	   }else{
		   $('.form-field__otp input').removeClass('error');
		   $('.error-message-container__otp').removeClass('show');
	   }
	}
	
	if($pClavePersonal!=null){
	   if($pClavePersonal.html()!=''){
		   $('div.clave-personal input').addClass('error');
	   }else{
		   $('div.clave-personal input').removeClass('error');
	   }
	}
	
	if($pToken!=null){
	   if($pToken.html()!=''){
		   $('div.token input').addClass('error');
	   }else{
		   $('div.token input').removeClass('error');
	   }
	}
}

function updateCounter () {
	let $counter = $('#formAutenticar\\:counter');
	const initialText = $counter.text();
	let initialTime = 60;
	let countdownInterval;

	const mediaQuery = window.matchMedia('(max-width: 768px)')
	const formatTime = function(seconds) {
		const minutes = Math.floor(seconds / 60);
		const remainingSeconds = seconds % 60;

		const formattedMinutes = String(minutes).padStart(2, '0');
		const formattedSeconds = String(remainingSeconds).padStart(2, '0');

		const timeString = `${formattedMinutes}:${formattedSeconds}`

		return mediaQuery.matches
			? `<strong>${timeString}</strong>`
			: timeString;
	}
	const updateCountdown = function() {
		if (initialTime < 0) {
			clearInterval(countdownInterval);
			return;
		}
		$counter.html(initialText+formatTime(initialTime));
		initialTime--;
	}
	updateCountdown();
	countdownInterval = setInterval(updateCountdown, 1000);
}

