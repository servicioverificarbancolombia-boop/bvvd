function handleDisableButton(data) {
	
	var element = document.getElementById(data.source.id);
	var status = data.status;
	
	if (status != "success") {
		element.disabled = true;
		inhabilitaControles();
		addClass('buttonDisabled', element);
	} else {
		element.disabled = false;
		habilitaControles();
		removeClass('buttonDisabled', element);
	}
}

function addClass( classname, element ) {
    var cn = element.className;
    //test for existance
    if( cn.indexOf( classname ) != -1 ) {
    	return;
    }
    //add a space if the element already has class
    if( cn != '' ) {
    	classname = ' '+classname;
    }
    element.className = cn+classname;
}

function removeClass( classname, element ) {
    var cn = element.className;
    var rxp = new RegExp( "\\s?\\b"+classname+"\\b", "g" );
    cn = cn.replace( rxp, '' );
    element.className = cn;
}

//These need to be global to be accessed by both functions.
var map, infoWindow, iterator,
	markers = [];

function initialize() {
	var locations = [
		['<p><img src="company_logo_resize.png" alt="Companylogo" align="top" /></p><p><b>Customer One</b></p><p>	Product One	</p><p>	Phone Number One </p>', 4.6367495, -74.0982615, 1],
		['<p><img src="company_logo_resize.png" alt="Companylogo" align="top" /></p><p><b>Customer Two</b></p><p>	Product Two	</p><p>	Phone Number Two </p>', 4.6502662, -74.1288172, 2],
		['<p><img src="company_logo_resize.png" alt="Companylogo" align="top" /></p><p><b>Customer Three</b></p><p>	Product Three </p><p> Phone Number Three </p>', 4.6613874, -74.1341387, 3],
		['<p><img src="company_logo_resize.png" alt="Companylogo" align="top" /></p><p><b>Customer Four</b></p><p>	Product Four </p><p> Phone Number Four </p>', 4.6630983, -74.1325079, 4],
		['<p><img src="company_logo_resize.png" alt="Companylogo" align="top" /></p><p><b>Customer Five</b></p><p>	Product Five </p><p> Phone Number Five </p>', 4.6582222,-74.1196333, 5]
	];

	//Setup map
	map = new google.maps.Map(document.getElementById('map'), {
		zoom: 12,
		center: new google.maps.LatLng(4.6367495, -74.0982615),
		mapTypeId: google.maps.MapTypeId.ROADMAP
	});

	//Create a single infowindow that will be shared by all markers
	infowindow = new google.maps.InfoWindow();
	iterator = 0; //Setup global iterator to go through markers
	for (var i = 0; i < locations.length; i++)
		setTimeout(function () {
			//i can't be passed through because, by the time setTimeout executes, i == locations.length
			addMarker(locations);
		}, i * 500); //Execute addMarker every 500ms
}

function addMarker(locations) {
	//Use loc as the location array
	var loc = locations[iterator++];
	//Create new marker and place on `map`
	var marker = new google.maps.Marker({
		position: new google.maps.LatLng(loc[1], loc[2]),
		map: map,
		draggable: false,
		animation: google.maps.Animation.DROP
	});

	//Add an event listener to the marker
	google.maps.event.addListener(marker, 'click', function () {
		infowindow.setContent(loc[0]);
		infowindow.open(map, marker);
	});

	//Add new marker to list of markers (to keep track of them)
	markers.push(marker);
}

/************************************************************/
function buscar(campos,id){
	for(var i=0;i<campos.length;i++){
		var campoSelect=campos[i];
		if(campoSelect.id.indexOf(id)>-1){
			return campoSelect;
		}
	}
}

function buscarInput(id){
	return buscar(document.getElementsByTagName("input"),id);
}

function buscarCombo(id){
	return buscar(document.getElementsByTagName("select"),id);
}	

function buscarViculo(id){
	return buscar(document.getElementsByTagName("a"),id);
}

function getComponent(id,type){
	if(type=='input'){
	    return buscarInput(id);	
	}else if(type=='select'){
		return buscarCombo(id);	
	}else if(type=='a'){
		return buscarViculo(id);
	} 
}

function onChangeTipoDoc(){
	
	var numeroDocumento=getComponent('numeroDocumento','input');
	var claveVirtual=getComponent('claveVirtual','input');
	var clavePersonal=getComponent('clavePersonal','input');
	var token=getComponent('token','input');
	
	if(numeroDocumento!=null){ 
		numeroDocumento.value='';
	}
	
	if(claveVirtual!=null){    
		claveVirtual.value='';
	}
	
	if(clavePersonal!=null){   
		clavePersonal.value='';
	}
	
	if(token!=null){      
		token.value='';
	}
	
	var $msjGral = $('div.div-mensajes-gral');
	$msjGral.hide();
}

function inhabilitaControles(){
	
	var tipoDocumento = document.getElementById('selectInputTipoDoc');
	var numeroDocumento=getComponent('numeroDocumento','input');
	var claveVirtual=getComponent('claveVirtual','input');
	var clavePersonal=getComponent('clavePersonal','input');
	var token=getComponent('token','input');
	var buttonSubmit=getComponent('btnSubmitCont','input');
	var linkEnrolamiento=getComponent('linkEnrolamiento','a');
	var numDocEnmascarado = getComponent('numeroDocumentoEnmasc', 'input');
	
	if(tipoDocumento!=null){
		tipoDocumento.setAttribute('onclick','return false;');
		tipoDocumento.setAttribute('style','pointer-events:none');
	}
	
	if(numeroDocumento!=null){ 
		numeroDocumento.readOnly=true;
	}
	
	if(numDocEnmascarado!=null) {
		numDocEnmascarado.readOnly=true;
	}
	
	if(claveVirtual!=null){    
		claveVirtual.readOnly=true;
	}
	
	if(clavePersonal!=null){   
		clavePersonal.readOnly=true;
	}
	
	if(token!=null){     
	    token.readOnly=true;
	}
	
	if(buttonSubmit!=null){
		buttonSubmit.disabled=true;
	}
	
	if(linkEnrolamiento!=null){
		linkEnrolamiento.disabled=true;
	}
	
	muestraMessage();
}

function habilitaControles(){
	
	var tipoDocumento = document.getElementById('selectInputTipoDoc');
	//var numeroDocumento=getComponent('numeroDocumento','input');
	var claveVirtual=getComponent('claveVirtual','input');
	//var clavePersonal=getComponent('clavePersonal','input');
	var token=getComponent('token','input');
	var buttonSubmit=getComponent('btnSubmitCont','input');
	var linkEnrolamiento=getComponent('linkEnrolamiento','a');
	
	if(tipoDocumento!=null){
		tipoDocumento.setAttribute('onclick','comboClick();');
		tipoDocumento.setAttribute('style','pointer-events:auto');
	}
	
	if(token!=null){     
	    token.readOnly=false;
	}
	
	if(buttonSubmit!=null){
		buttonSubmit.disabled=false;
	}
	
	if(linkEnrolamiento!=null){
		linkEnrolamiento.disabled=false;
	}
	
	muestraMessage();
}

function getMessages(field){
	var tablas =  document.getElementsByTagName("table");
	
	var mensaje1=null;
	var mensaje2=null;
	
	if(tablas!=null){
		for(var i=0; i<tablas.length; i++) {
			var tablaMessage = tablas[i];
			if(tablaMessage.id.search("tablaGlobalMessages"+field)>-1){
				if(tablaMessage.firstChild) {
					tbody = tablaMessage.firstChild;
					if(tbody.firstChild){
						
						tr1   = tbody.firstChild;	
					    if(tr1.firstChild){
					    	td1   = tr1.firstChild;
					    	mensaje1=td1.textContent;
					    	estiloMensaje1=td1.className;
					    }
					    
					    if(tr1.nextSibling){
					    	tr2=tr1.nextSibling;
				    		if(tr2.firstChild){
				    			td2=tr2.firstChild;
				    			mensaje2=td2.innerHTML;
						    	estiloMensaje2=td2.className;
						    	break;
				    		}
				    	}
					    break;
					}
				}
			}
		}	
	}

	return {
		mensaje1,
		mensaje2
	}
}

function muestraMessage(field){
	
	var tablas =  document.getElementsByTagName("table");
	
	var mensaje1=null;
	var mensaje2=null;
	var estiloMensaje1=null;
	var estiloMensaje2=null;
	
	var esExplorer=false;
	if(navigator.appName == "Microsoft Internet Explorer"){
		esExplorer=true;
	}
	
	if(tablas!=null){
		for(var i=0; i<tablas.length; i++) {
			var tablaMessage = tablas[i];
			if(tablaMessage.id.search("tablaGlobalMessages"+field)>-1){
				if(tablaMessage.firstChild) {
					tbody = tablaMessage.firstChild;
					if(tbody.firstChild){
						
						tr1   = tbody.firstChild;	
					    if(tr1.firstChild){
					    	td1   = tr1.firstChild;
					    	mensaje1=td1.textContent;
					    	estiloMensaje1=td1.className;
					    }
					    
					    if(tr1.nextSibling){
					    	tr2=tr1.nextSibling;
				    		if(tr2.firstChild){
				    			td2=tr2.firstChild;
				    			mensaje2=td2.innerHTML;
						    	estiloMensaje2=td2.className;
						    	break;
				    		}
				    	}
					    break;
					}
				}
			}
		}	
	}
	
	if(mensaje1!=null){

		if(mensaje2==null){
			//alert('Mensaje1: '+mensaje1+' Clase1: '+estiloMensaje1);
			
			var div = document.getElementById('divMessage'+field);
			while(div.firstChild) {
				div.removeChild(div.firstChild);
			}
			
			var tabla=document.createElement('table');
			tabla.setAttribute('class','tablaMessage');
			tabla.setAttribute('align','center');
			tabla.setAttribute('cellspacing','0'); 
			tabla.setAttribute('cellpadding','0');
			
			var tbody=document.createElement('tbody');
			var tr1=document.createElement('tr');
			
			var td1=document.createElement('td');
			td1.setAttribute('class',estiloMensaje1);
			td1.innerHTML=mensaje1;
				
			tr1.appendChild(td1);
			
			tbody.appendChild(tr1);
			tabla.appendChild(tbody);
			div.appendChild(tabla);
			div.setAttribute("class", "div-mensajes-gral");
			
		}else{
			var div = document.getElementById('divMessage'+field);
			while(div.firstChild) {
				div.removeChild(div.firstChild);
			}
			
			var tabla=document.createElement('table');
			tabla.setAttribute('class','tablaMessage');
			tabla.setAttribute('align','center');
			tabla.setAttribute('cellspacing','0'); 
			tabla.setAttribute('cellpadding','0');
			
			var tbody=document.createElement('tbody');
			var tr1=document.createElement('tr');
			
			var td1=document.createElement('td');
			td1.setAttribute('class','mensajeHeaderMessage');
			td1.innerHTML=mensaje1;
				
			tr1.appendChild(td1);
			tr1.appendChild(td1);
			
			var tr2=document.createElement('tr');
			var td2=document.createElement('td');
			td2.setAttribute('class',estiloMensaje2);
			td2.innerHTML=mensaje2;
				
			tr2.appendChild(td2);
			
			tbody.appendChild(tr1);
			tbody.appendChild(tr2);
			
			tabla.appendChild(tbody);
			div.appendChild(tabla);
			div.setAttribute("class", "div-mensajes-gral");
		}
	} else {
		var $msjGral = $('divMessage'+field+' div.div-mensajes-gral');
		$msjGral.hide();
	}
}

function onKeyPressIntro(event){
	var aplicaEvento=true;
	var keyCode = event.keyCode ? event.keyCode : event.which;
	if(keyCode==13){
		var boton = getComponent('btnSubmitCont','input');
		if(boton!=null){
			if(keyCode==13){ 
		    	aplicaEvento=false;
			    boton.click();
			}
		}else{
			var linkEnrolamiento = getComponent('linkEnrolamiento','a');
			if(linkEnrolamiento!=null){
				aplicaEvento=false;
				linkEnrolamiento.click();
			}
		}
	}
	return aplicaEvento;
}

function nextFocus(){
	
	var numeroDocumento  = getComponent('numeroDocumento','input');
	var claveVirtual     = getComponent('claveVirtual','input');
	var otp     		 = getComponent('otp','input');
	var clavePersonal    = getComponent('clavePersonal','input');
	var token            = getComponent('token','input');
	var buttonSubmit     = getComponent('btnSubmitCont','input');
	var linkEnrolamiento = getComponent('linkEnrolamiento','a');
	
	var $pNumeroDocumento = null;
	var $pClaveVirtual    = null;
	var $pOtp    		  = null;
	var $pClavePersonal   = null;
	var $pToken           = null;
	
	if(numeroDocumento!=null){ $pNumeroDocumento = $('#pNumeroDocumento');}
	if(claveVirtual   !=null){ $pClaveVirtual    = $('#pClaveVirtual');}
	if(otp   		  !=null){ $pOtp    		 = $('#pOtp');}
	if(clavePersonal  !=null){ $pClavePersonal   = $('#pClavePersonal');}
	if(token          !=null){ $pToken           = $('#pToken');}
	
	var errorTipoDocumento   = false;
	var errorNumeroDocumento = false;
	var errorClaveWeb        = false;
	var errorClaveVirtual    = false;
	var errorOtp    		 = false;
	var errorClavePersonal   = false; 
	var errorClaveToken      = false;
	
	if(numeroDocumento!=null){
		if($pNumeroDocumento.html()!=''){
			errorNumeroDocumento=true;
		}
	}
	
	if(claveVirtual!=null){
		if($pClaveVirtual.html()!=''){
			errorClaveVirtual=true;
		}
	}
	
	if(otp!=null){
		if($pOtp.html()!=''){
			errorOtp=true;
		}
	}
	
	if(clavePersonal!=null){
		if($pClavePersonal.html()!=''){
			errorClavePersonal=true;
		}
	}
	
	if(token!=null){
		if($pToken.html()!=''){
			errorClaveToken=true;
		}
	}
	
	if(numeroDocumento!=null){
		if(errorNumeroDocumento && !errorTipoDocumento){
			numeroDocumento.focus();
		}else if(((numeroDocumento.value==null || numeroDocumento.value=='')) && claveVirtual==null && clavePersonal==null && token==null){
			numeroDocumento.focus();
		}
	}
	
	if(claveVirtual!=null){
		if(errorClaveVirtual && !errorOtp && !errorNumeroDocumento){
			claveVirtual.focus();
		}else if(!errorClaveVirtual && otp==null){
			claveVirtual.focus();
		}else if(!errorClaveVirtual && otp!=null && (otp.value!=null && otp.value=='')){
			otp.focus();
		}else if(errorOtp){
			otp.focus();
		}else if(errorNumeroDocumento){
			numeroDocumento.focus();
		}
	}
	
	if(clavePersonal!=null){
		if(errorClavePersonal && !errorNumeroDocumento){
			clavePersonal.focus();
		}else if(!errorNumeroDocumento){
			clavePersonal.focus();
		}else if(errorNumeroDocumento){
			numeroDocumento.focus();
		}
	}
	
	if(token!=null){
	    if(errorClaveToken && !errorClavePersonal && !errorNumeroDocumento){
			token.focus();
		}else if(!errorClaveToken && clavePersonal==null){
			token.focus();
		}else if(!errorClaveToken && clavePersonal!=null && (clavePersonal.value!=null && clavePersonal.value!='')){
			token.focus();
		}else if(errorClavePersonal){
			clavePersonal.focus();
		}else if(errorNumeroDocumento){
			numeroDocumento.focus();
		}
	}
	
	if(linkEnrolamiento!=null){
		linkEnrolamiento.focus();
	}
	
	muestraMessage();
}

function ponerFocoEnLink(){
	var linkEnrolamiento = getComponent('linkEnrolamiento','a');
	if(linkEnrolamiento!=null){
		linkEnrolamiento.focus();
	}
	
	muestraMessage();
}

function findPos(obj) {
	var curleft = curtop = 0;
	if (obj.offsetParent) {
		do {
			curleft += obj.offsetLeft;
			curtop += obj.offsetTop;
		} while (obj = obj.offsetParent);
		return [curleft,curtop];
	}
}

function comboClick() {
	var divSelectInputTipoDoc = document.getElementById('selectInputTipoDoc');
	var divSelectInputContentTipoDoc = document.getElementById('selectInputContentTipoDoc');
	if(divSelectInputContentTipoDoc.style.display != 'block') {
		var pos = findPos(divSelectInputTipoDoc);
		divSelectInputContentTipoDoc.style.left = pos[0] + 'px';
		divSelectInputContentTipoDoc.style.top = (pos[1] + divSelectInputTipoDoc.offsetHeight) + 'px';
		divSelectInputTipoDoc.className = 'combo desplegado';
		divSelectInputContentTipoDoc.style.display = 'block';
		divSelectInputContentTipoDoc.className = 'combo-content-scroll';
	} else {
		divSelectInputTipoDoc.className = 'combo plegado';
		divSelectInputContentTipoDoc.style.display = 'none';
	}
}

function selectItemCombo(item){
	var cod = item.id.split(';')[0];
	var desc = item.id.split(';')[1];
	document.getElementById(idSelectedTipoDocCod).value = cod;
	document.getElementById(idSelectedTipoDocCod).attributes['value'].nodeValue = cod;
	document.getElementById(idSelectedTipoDocDesc).textContent = desc;
	document.getElementById(idLimpiarFormularioBtn).click();	
	comboClick();
}

function onFocusNumDocumento(){
	var divSelectInputContentTipoDoc = document.getElementById('selectInputContentTipoDoc');
		if ( divSelectInputContentTipoDoc != null ) {
		divSelectInputContentTipoDoc.className = 'combo-content-scroll';
		if(divSelectInputContentTipoDoc.style.display == 'block') {
			comboClick();
		}
	}
}

function onFocusNumDocEnmascarado() {
	var numDocumentoEnmasc = document.getElementById('formAutenticar:numeroDocumentoEnmasc');
	var numDocumento = document.getElementById('formAutenticar:numeroDocumento');
	
	if ( ! numDocumento.readOnly && numDocumento.readOnly != "readonly") {
		numDocumentoEnmasc.style.display = 'none';
		numDocumento.style.display = 'block';
		numDocumento.value = '';
		numDocumento.focus();
	}
}

function addLoadEvent(func) {
    var oldonload = window.onload;
    if (typeof window.onload != 'function') {
        window.onload = func;
    } else {
        window.onload = function() {
            if (oldonload) {
	        oldonload();
            }
            func();
        };
    }
}


function replaceCharactersAndMask(ipe, hrpi, event){
	event.target.value = event.target.value.replace(/[^0-9*]/g, '')
	inputMask(ipe, hrpi);
}


function inputMask(ipe, hrpi){
	  var hrpe = document.getElementById(hrpi);
	  var c = ipe.value.replace('*','');
	  var d = Math.abs(ipe.value.length - hrpe.value.length);
	  if (ipe.value.length > hrpe.value.length ) {
	      hrpe.value = hrpe.value + ipe.value.substring(ipe.value.length - d, ipe.value.length);
	      ipe.value = ipe.value.replace(/(.)/g,'*');
	      return;
	  }
	  
	  if (ipe.value.length == hrpe.value.length ) {
		  ipe.value = ipe.value.replace(/(.)/g,'*');
	      return;
	  }
	  
	  if (ipe.value.length <= 1 ) {
	      hrpe.value = c;
	      ipe.value = ipe.value.replace(/(.)/g,'*');
	      return;
	  }
	  
	  if (ipe.value.length < hrpe.value.length ) {
	      hrpe.value = hrpe.value.substring(0, hrpe.value.length - d);
	      ipe.value = ipe.value.replace(/(.)/g,'*');
	  }
}