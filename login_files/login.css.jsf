section.home div#fullpage div.section#third div.canales div.wrap div.contenedor-mas-canales a.mostrar-mas-canales i.icono.ico-rojo-arriba {
    background: url("https://transacciones.davivienda.com/transaccional/javax.faces.resource/ico-rojo-arriba.png.jsf?ln=img") no-repeat center center;
