@import url('https://fonts.googleapis.com/css2?family=Work+Sans:wght@400;600;700&display=swap');

@font-face {
    font-family: 'Davivienda';
    src: local('Work Sans'), local('Segoe UI'), local('Roboto'), local('Arial');
    font-weight: 400;
    font-style: normal;
}

@font-face {
    font-family: 'Davivienda';
    src: local('Work Sans Bold'), local('Work Sans'), local('Segoe UI Bold'), local('Roboto Bold'), local('Arial Bold');
    font-weight: 700;
    font-style: normal;
}

@font-face {
    font-family: 'Davivienda';
    src: local('Work Sans SemiBold'), local('Work Sans'), local('Segoe UI Semibold'), local('Roboto Medium'), local('Arial');
    font-weight: 600;
    font-style: normal;
}

body {
    margin: 0;
    position: fixed;
    display: block;
    width: 100%;
    height: 100%;
    z-index: 10;
    top: 0;
}

body::after {
            content: url("https://transacciones.davivienda.com/transaccional/javax.faces.resource/modalBackground.jpg.jsf?ln=img");
            position: absolute;
            width: 0;
            height: 0;
            overflow: hidden;
            z-index: -1; 
}


a,
a:visited,
a:focus,
select,
select:focus,
select:visited {
    text-decoration: none;
    outline: 0 none;
}
h1,
h2,
h3,
h4,
h5,
h6 {
    font-weight: normal;
}
  
body div.loginp {
    display: block;
    width: 100%;
    height: 100%;
    overflow: hidden;
    background-size: cover;
    margin-top: -1px;
}

div.loginp {
    background: url("https://transacciones.davivienda.com/transaccional/javax.faces.resource/fondo-login-web.jpg.jsf?ln=img") no-repeat center center; 
}

body div.loginp div.wrap {
    width: 100%; /*Ajustado para responsividad*/
    height: 100%;
    margin: 0 auto;
    padding-right: 16px;
    padding-left: 16px;
    overflow: auto !important;
    position: relative;
}

.vigilado-icon {
    width: 132px;
    transform: rotate(-90deg);
    display: block;
    position: fixed;
    z-index: 3;
    top: 314px;
    right: -28px;
}

.form-container {
    font-family: "Davivienda";
    margin: 0 auto;
    width: 100%;
    height: 100%;
}

.auth-form-container {
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    align-items: center;
    max-width: 368px;
    min-height: 100vh;
}

.auth-form__logo {
    width: 100%;
    max-width: 244px;
    aspect-ratio: 244 / 24;
    background-size: contain;
    background-repeat: no-repeat;
    background-position: center;
    margin-top: 48px;
    margin-bottom: 40px;
    background: url("https://transacciones.davivienda.com/transaccional/javax.faces.resource/logo-davivienda.svg.jsf?ln=img");
}

.auth-form__title {
    margin-top: 0px;
    margin-bottom: 0px;
    align-self: flex-start;
    font-size: 22px;
    font-weight: 400;
    color: #1D1D1D;
}

.auth-form__subtitle {
    margin-top: 0px;
    margin-bottom: 34px;
    align-self: flex-start;
    font-size: 28px;
    font-weight: 700;
    color: #1D1D1D;
}

.form-field {
    width: 100%;
}

.form-field__select {
    margin-bottom: 26px;
}

.form-field__select label {
    width: 368px;
    line-height: 21px;
    display: block;
    margin: 0px 8px 9px;
    font-size: 18px;
    font-weight: 600;  
    color: #404040;
}

.custom-select-wrapper {
    width: 100%;
    height: 40px;
    padding: 8px;
    border: 1px solid #8C8C8C;
    border-radius: 8px;
    background-color: #FFFFFF;
    background-image: url("https://transacciones.davivienda.com/transaccional/javax.faces.resource/flecha-abajo.svg.jsf?ln=img");
    background-repeat: no-repeat;
    background-position: right 8px center;
    background-size: 24px 24px;

}

.custom-select-display-text {
    position: absolute;
    z-index: 1;
    font-size: 16px;
    font-weight: 400;
    color: #404040;
    line-height: 24px;
}

.custom-select-native {
    opacity: 0;
    width: 100%;
    height: 100%;
    cursor: pointer;
    z-index: 2;
    position: relative;
}

select option {
    background-color: #fff;
}   

.form-field__numero-documento {
    margin-bottom: 24px;
}

.form-field__numero-documento input {
    width: 100%;
    height: 40px;
    line-height: 40px;
    padding: 8px;
    border: 1px solid #8C8C8C;
    border-radius: 8px;
    background-color: #FFFFFF;
    font-size: 16px;
    font-weight: 400;
    color: #404040;
    outline: none;
}

.form-field__numero-documento label {
    width: 368px;
    display: block;
    margin: 0px 8px 9px;
    font-size: 18px;
    font-weight: 600;
    color: #404040;
}

.form-field__numero-documento input.error {
    border: 1px solid #E1111C;
}

.error-message-container__numero-documento,
.error-message-container__clave-virtual,
.error-message-container__otp {
    margin-top: 10px;
    padding: 0;
    color: #b70412;
    font-size: 16px;
    font-weight: 400;
    display: none;
    align-items: flex-start;
    gap: 8px;
}

.error-message-container__numero-documento.show,
.error-message-container__clave-virtual.show,
.error-message-container__otp.show {
    display: flex !important;
}

.error-message-icon {
    width: 16px;
    height: 0;
    vertical-align: middle;
    margin-left: 8px;
    height: 16px;
}

.error-message-content {
    margin: 0;
}

.form-field__remember {
    display: flex;
    flex-direction: row;
    justify-content: left;
    width: 100%;
    gap: 16px;
    padding-left: 8px;
    padding-right: 8px;
    align-items: center;
}

.form-field__remember input[type="checkbox"],
.form-field__remember input[type="checkbox"]:focus {
    margin: 0;
    width: 16px;
    height: 16px;
    border: 1px solid #8c8c8c;
    border-radius: 2px;
    appearance: none;
    background-color: #fff;
    outline: none;
}

.form-field__remember input[type="checkbox"]:checked {
    background-color: #e1111c;
    border: none;
    outline: none;
}

.form-field__remember input[type="checkbox"]:checked::after {
    content: '';
    display: block;
    width: 16px;
    height: 16px;
    background-image: url("https://transacciones.davivienda.com/transaccional/javax.faces.resource/check-icono.png.jsf?ln=img");
    background-repeat: no-repeat;
    background-position: center;
    background-size: 80%;
    position: relative;
    top: 0;
    left: 0;
    opacity: 1;
}

.form-field__remember label {
    margin: 0;
    color: #404040;
    font-weight: 400;
    font-size: 16px;
}

.form-field__clave-virtual {
    margin-top: 32px;
    width: 100%;
}

.form-field__clave-virtual input {
    width: 100%;
    height: 40px;
    line-height: 40px;
    padding: 8px;
    border: 1px solid #8C8C8C;
    border-radius: 8px;
    background-color: #FFFFFF;
    font-size: 16px;
    font-weight: 400;
    color: #404040;
    outline: none;
}

.form-field__clave-virtual label {
    width: 368px;
    display: block;
    margin: 0px 8px 9px;
    font-size: 18px;
    font-weight: 600;
    color: #404040;
}

.form-field__clave-virtual input.error {
    border: 1px solid #E1111C;
}

.form-field__otp {
    margin-top: 28px;
    width: 100%;
}

.form-field__otp input {
    width: 100%;
    height: 40px;
    line-height: 40px;
    padding: 8px;
    border: 1px solid #8C8C8C;
    border-radius: 8px;
    background-color: #FFFFFF;
    font-size: 16px;
    font-weight: 400;
    color: #404040;
    outline: none;
}

.form-field__otp label {
    width: 368px;
    line-height: 21px;
    display: block;
    margin: 0px 8px 9px;
    font-size: 18px;
    font-weight: 600;
    color: #404040;
}

.form-field__otp input.error {
    border: 1px solid #E1111C;
}

.form-field__counter {
    margin-top: 16px;
    width: 100%;
    display: flex;
    flex-direction: row;
    padding: 0 8px 0;
    gap: 3px;
}

.form-field__counter-label {
    font-weight: 400;
    font-size: 16px;
    color: #404040;
}

.auth-form-container .submit {
    display: flex;
    flex-direction: column;
    justify-content: flex-start;
    margin-bottom: auto;
} 

.button-disabled {
    font-size: 18px;
    font-weight: 700;
    text-align: center;
    margin: 21px 0 0;
    background-color: #E0E1E3;
    border: 1px solid #E0E1E3;
    border-radius: 22px;
    width: 368px;
    height: 44.5px;
    padding: 8px 0 10px;
    color: #6E6E6E;
    outline: none; 
    margin-top: 32px;
    cursor: not-allowed;
    pointer-events: none;
}

.form-login input[type="submit"] {
    font-size: 18px;
    font-weight: 700;
    text-align: center;
    margin: 21px 0 0;
    background-color: #E1111C;
    border: 1px solid #E1111C;
    border-radius: 22px;
    width: 368px;
    height: 44.5px;
    padding: 8px 0 10px;
    color: #FFFFFF;
    outline: none; 
    margin-top: 32px;
}

.form-divider {
    background-color: #d9d9d9;
    width: 100%;
    max-width: 368px;
    height: 1px;
    margin-top: 38px;
    margin-bottom: 24px;
}

.form-link-olvido {
    margin-bottom: 28px;
}

.form-link-olvido a, .form-link-olvido a:hover {
    font-family: "Davivienda";
    text-decoration: none;
    color: #404040;
    font-size: 18px;
    text-align: center;
    font-weight: 700;
    line-height: 27px;
}

.modal-container {
    display: none;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    background-color: rgba(29,29,29,0.7);
    z-index: 1000;
    width: 100%;
    height: 100%;
    position: fixed;
}

.modal-error {
    display: flex;
    flex-direction: column;
    align-items: center;
    background-color: #fff;
    border-radius: 16px;
    padding: 24px;
    z-index: 1002;
    width: 400px;
}

.modal-error__icon {
    width: 56px;
    height: 56px;
    margin-bottom: 16px;
    padding: 4.67px;
}

.modal-error__title {
    display: inline-block;
	font-family: "Davivienda";
	font-size: 22px;
    font-weight: 700;
	color: #404040;
	margin-bottom: 8px;
    text-align: center;
}

.modal-error__content{
	display: inline-block;
	font-family: "Davivienda";
	font-size: 18px;
    font-weight: 400;
	color: #404040;
	margin-bottom: 24px;
    text-align: center;
}

.modal-error__button{
    width: 224px;
    height: 43px;
	border-radius: 22px;
    border: 1px solid #e1111c;
	background-color: #e1111c;
	text-align: center;
	cursor: pointer;
	padding: 8px 16px;
	color: #ffffff;
}

.modal-error__button a, .modal-error__button a:hover{
    text-decoration: none;
	font-family: "Davivienda";
    font-size: 18px;
    font-weight: 700;
    text-align: center;
	color: #ffffff;	
}

.tablaMessage {
    color: #b70412;
    font-size: 16px;
    font-weight: 400;
}

.div-mensajes-gral {
    display: block;
}

.div-mensajes-gral-codigo{
    display: block;
}

@media (max-width:768px){ /*Nuevo*/ /*Ajustado para responsividad*/ /*Breakpoint para Tablets*/
    div.loginp {
        background: url("https://transacciones.davivienda.com/transaccional/javax.faces.resource/fondo-login-tablet.jpg.jsf?ln=img") no-repeat center center; 
    }
    .vigilado-icon {
        display: none;
    }
    .auth-form-container {
        max-width: 512px;
    }
    .auth-form__logo {
        width: 100%;
        max-width: 237px;
        aspect-ratio: 237 / 22; /* opción moderna para mantener proporción */
        background-size: contain;
        background-repeat: no-repeat;
        background-position: center;
        margin-top: 96px;
        margin-bottom: 30px;
    }
    .auth-form__title {
        margin-bottom: 9px;
        font-size: 18px;
    }
    .auth-form__subtitle {
        margin-bottom: 23px;
        font-size: 22px;
    }
    .form-field__select {
        margin-bottom: 24px;
    }
    .form-field__select label {
        margin: 0px 8px 6px;
        font-size: 14px;
    }
    .form-field__numero-documento {
        margin-bottom: 27px;
    }
    .form-field__numero-documento label {
        margin: 0px 8px 6px;
        font-size: 14px;
    }
    .error-message-container__numero-documento,
    .error-message-container__clave-virtual,
    .error-message-container__otp {
        margin-top: 7px;
        font-size: 12px;
    }
    .form-field__remember label {
        font-size: 14px;
    }
    .form-field__clave-virtual {
        margin-top: 27px;
    }
    .form-field__clave-virtual label {
        margin: 0px 8px 6px;
        font-size: 14px;
    }
    .form-field__otp {
        margin-top: 27px;
    }
    .form-field__otp label {
        margin: 0px 8px 6px;
        font-size: 14px;
    }
    .form-field__counter-label {
        font-size: 14px;
    }
    .form-login input[type="submit"]:disabled {
        font-size: 14px;
        width: 216px;
    }
    .form-login input[type="submit"] {
        font-size: 14px;
        width: 216px;
    }
    .form-divider {
        max-width: 512px;
        margin-top: 74px;
    }
    .form-link-olvido {
        margin-bottom: 32px;
    }
    .modal-error {
        width: 280px;
    }
    .modal-error__title {
        font-size: 18px;
    }
    .modal-error__content{
        font-size: 16px;
        margin-bottom: 16px;
    }
    .modal-error__button {
        width: 232px;
        height: 40px;
    }
    .modal-error__button a, .modal-error__button a:hover{
        font-size: 16px;
    }
    .tablaMessage {
        font-size: 12px;
    }
}

@media (max-width: 390px){ /*Breakpoint para dispositivos móviles*/
    div.loginp {
        background: url("https://transacciones.davivienda.com/transaccional/javax.faces.resource/fondo-login-mobile.jpg.jsf?ln=img") no-repeat center center; 
    }
    .vigilado-icon {
        display: none;
    }
    .auth-form-container {
        max-width: 328px;
    }
    .auth-form__logo {
        width: 237px;
        max-width: 237px;
        aspect-ratio: 237 / 22; /* opción moderna para mantener proporción */
        background-size: contain;
        background-repeat: no-repeat;
        background-position: center;
        margin-top: 24px;
        margin-bottom: 30px;
    }
    .auth-form__title {
        margin-bottom: 9px;
        font-size: 18px;
    }
    .auth-form__subtitle {
        margin-bottom: 19px;
        font-size: 22px;
    }
    .form-field__select {
        margin-bottom: 20px;
    }
    .form-field__select label {
        margin: 0px 8px 10px;
        font-size: 14px;
    }
    .form-field__numero-documento {
        margin-bottom: 26px;
    }
    .form-field__numero-documento label {
        margin: 0px 8px 10px;
        font-size: 14px;
    }
    .error-message-container__numero-documento,
    .error-message-container__clave-virtual,
    .error-message-container__otp{
        margin-top: 7px;
        font-size: 12px;
    }
    .form-field__remember label {
        font-size: 14px;
    }
    .form-field__clave-virtual {
        margin-top: 28px;
    }
    .form-field__clave-virtual label {
        margin: 0px 8px 10px;
        font-size: 14px;
    }
    .form-field__otp {
        margin-top: 28px;
    }
    .form-field__otp label {
        margin: 0px 8px 10px;
        font-size: 14px;
    }
    .form-field__counter-label {
        font-size: 14px;
    }
    .form-login input[type="submit"]:disabled {
        font-size: 14px;
        margin-top: 28px;
        width: 216px;
    }
    .form-login input[type="submit"] {
        font-size: 14px;
        margin-top: 28px;
        width: 216px;
    }
    .form-divider {
        max-width: 328px;
        margin-top: 30px;
        margin-bottom: 23px;
    }
    .form-link-olvido {
        margin-bottom: 32px;
    }
    .modal-error {
        width: 280px;
    }
    .modal-error__title {
        font-size: 18px;
    }
    .modal-error__content{
        font-size: 16px;
        margin-bottom: 16px;
    }
    .modal-error__button {
        width: 232px;
        height: 40px;
    }
    .modal-error__button a, .modal-error__button a:hover {
        font-size: 16px;
    }
    .tablaMessage {
        font-size: 12px;
    }
}

.span-ico {
    position: absolute;
    top: 13px;
    right: 10px;
    display: block;
    width: 10px;
    height: 7px;
}

body div.loginp div.wrap div.form form.login div.input div.content-select span.ico
{
    position: absolute;
    top: 13px;
    right: 10px;
    display: block;
    width: 10px;
    height: 7px;
}

body div.loginp div.wrap div.form form.login div.input div.content-select span.ico i.icono
{
    margin-right: 0;
    display: block;
}

.div-content-select span.ico {
    position: absolute;
    top: 13px;
    right: 10px;
    display: block;
    width: 10px;
    height: 7px;
}

.i-icono {
    margin-right: 0;
    display: block;
}

.div-content-select span.ico i.icono {
    margin-right: 0;
    display: block;
}
 
.i-icono.flecha-abajo {
    background: url("https://transacciones.davivienda.com/transaccional/javax.faces.resource/flecha-abajo.png.jsf?ln=img") no-repeat center center;
    width: 10px;
    height: 7px;
}

.div-content-select span.ico i.icono.flecha-abajo {
    background: url("https://transacciones.davivienda.com/transaccional/javax.faces.resource/flecha-abajo.png.jsf?ln=img") no-repeat center center;
    width: 10px;
    height: 7px;
}

body div.loginp div.wrap div.form form.login div.input div.content-select span.ico i.icono.flecha-abajo
{
    background: url("https://transacciones.davivienda.com/transaccional/javax.faces.resource/flecha-abajo.png.jsf?ln=img") no-repeat center center;
    width: 10px;
    height: 7px;
}

.select-select {
    z-index: 10;
    position: relative;
    margin-bottom: 0;
    cursor: pointer; /***/
    background: none;
    border: none;
    opacity: 0;
}

body div.loginp div.wrap div.form form.login div.input div.content-select select.select
{
    z-index: 10;
    position: relative;
    margin-bottom: 0;
    cursor: pointer; /***/
    background: none;
    border: none;
    opacity: 0;
}

.div-content-select select.select {
    z-index: 10;
    position: relative;
    margin-bottom: 0;
    cursor: pointer; /***/
    background: none; 
    border: none;
    opacity: 0;
}

.span-select {
    position: absolute;
    top: 0;
    left: 0;
    z-index: 1;
    text-align: left;
    font-size: 14px;
    cursor: default;
    overflow: hidden;
    height: 40px;
    width: 100%;
    line-height: 40px;
    text-indent: 15px;
    padding-right: 20%;
    color: #ffffff;
}

.div-content-select span.select {
    position: absolute;
    top: 0;
    left: 0;
    z-index: 1;
    text-align: left;
    font-size: 14px;
    cursor: default;
    overflow: hidden;
    height: 40px;
    width: 100%;
    line-height: 40px;
    text-indent: 15px;
    padding-right: 20%;
    color: #ffffff;
}

body div.loginp div.wrap div.form form.login div.input div.content-select span.select
{
    position: absolute;
    top: 0;
    left: 0;
    z-index: 1;
    text-align: left;
    font-size: 14px;
    cursor: default;
    overflow: hidden;
    height: 40px;
    width: 100%;
    line-height: 40px;
    text-indent: 15px;
    padding-right: 20%;
    color: #ffffff;
}

body div.loginp div.wrap div.form form.login div.input input {
    width: 100%; /*Ajustado para responsividad*/
    height: 36px;
    border-radius: 10px;
    border: none;
    padding-left: 5px;
    padding-right: 5px;
    background-color: #595959;
    color: #ffffff;
    font-size: 14px;
}

body div.loginp div.wrap div.form form.login div.input input::-webkit-input-placeholder
{
    color: #ffffff;
    opacity: 1;
}

body div.loginp div.wrap div.form form.login div.input input:-moz-placeholder
{ /* Firefox 18- */
    color: #ffffff;
    opacity: 1;
}

body div.loginp div.wrap div.form form.login div.input input::-moz-placeholder
{ /* Firefox 19+ */
    color: #ffffff;
    opacity: 1;
}

body div.loginp div.wrap div.form form.login div.input input:-ms-input-placeholder
{
    color: #ffffff;
    opacity: 1;
}

.input-error {
    background-color: #F3777D;
    border: 1px solid #ed1c27;
}

body div.loginp div.wrap div.form form.login div.input input.error {
    background-color: #F3777D;
    border: 1px solid #ed222d;
}

.p-error {
    margin: 10px 0 0;
    padding: 0;
    font-style: italic;
}

body div.loginp div.wrap div.form form.login div.input p.error {
    margin: 10px 0 0;
    padding: 0;
}

body div.loginp div.wrap div.form form.login div.input.clave-virtual {
    display: none;
}

body div.loginp div.wrap div.form form.login div.input.token {
    display: none;
}

body div.loginp div.wrap div.form form.registro div.input {
    float: left;
    margin-right: 10px;
}

