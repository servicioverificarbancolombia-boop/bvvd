}
footer {
    position: fixed;
    display: block;
    height: 50px;
    background-color: #000;
    width: 100%;
    z-index: 10;
    bottom: 0px;
    color: #FFF;
}

.scroll-off {
    overflow: hidden !important;
}

.scroll-on {
    overflow: scroll !important;
    height: 100% !important;;
}
div.fat-footer div.wrap {
/*    width: 100%; Ajustado para responsividad*/
    margin: 0 auto;
    overflow: inherit;
    padding: 0 0;
    position: relative;
}
div.fat-footer div.wrap a.btn-cerrar-footer {
    position: absolute;
    top: -30px;
    right: 2%;  /*Ajustado para responsividad*/
    width: 20px;
    height: 20px;
}
div.fat-footer div.wrap h3 {
    color: #FFF;
    font-family: "HelveticaNeueLTStdMdCn", sans-serif;;
    margin: 0 0 15px;
}
div.fat-footer div.wrap ul {
    margin: 0 0 30px;
    padding: 0 0 0 10px;
    list-style: circle url("https://transacciones.davivienda.com/transaccional/javax.faces.resource/bullet.png.jsf?ln=img");
}
div.fat-footer div.wrap ul li {
    margin-bottom: 12px;
}
div.fat-footer div.wrap ul li a {
    color: #ffffff;
}
div.fat-footer div.wrap ul li a:hover {
    text-decoration: underline;
}
div.fat-footer div.wrap div.logos {
    width: 25%;
    float: left;
}
div.fat-footer div.wrap div.logos ul {
    list-style: none;
    margin: 0;
    padding: 0;
    text-align: center;
}
div.fat-footer div.wrap div.lineas-atencion {
    float: left;
}
div.fat-footer div.wrap div.lineas-atencion ul {
    margin: 0;
    padding: 0;
}
div.fat-footer div.wrap div.lineas-atencion ul li {
    list-style: none;
    text-transform: uppercase;
    margin-bottom: 0;
}
div.fat-footer div.wrap div.lineas-atencion ul li:nth-child(2n+1) {
    color: rgba(179, 179, 179, 0.6);
}
div.fat-footer div.wrap div.lineas-atencion ul li:nth-child(2n+2) {
    color: #FFF;
    font-family: "HelveticaNeueLTStdBdCn", sans-serif;
    font-size: 18px;
    margin-bottom: 12px;
}
div.fat-footer div.wrap div.links-interes {
    width: 25%;
    float: left;
}
div.fat-footer div.wrap div.links-interes ul.redes-sociales {
    list-style: none;
    margin: 0;
    padding: 0;
}
div.fat-footer div.wrap div.links-interes ul.redes-sociales li {
    display: inline-block;
    margin-right: 20px;
}
div.fat-footer div.wrap div.portales-davivienda {
    width: 25%;
    float: left;
}
footer div.wrap {
    /*    width: 100%; Ajustado para responsividad*/
    margin: 0 auto;
    /*padding: 0 0;*/ /*Ajustado para responsividad*/
    position: relative;
}
footer div.wrap a.mostrar-fat-footer {
    position: absolute;
    top: -20px;
    width: 60px;
    height: 20px;
    left: 50%;
    margin-left: -30px;
}
footer div.wrap div.legales {
    /*float: left;  Nuevo Ajustado para responsividad*/ 
    overflow: hidden;
}
footer div.wrap div.legales img {
    margin: 15px 20px 0 0;
    float: left;
    width: 140px;
}
footer div.wrap div.legales p {
/*    float: left; Nuevo Ajustado para responsividad*/
    text-align: center; /*Nuevo Ajustado para responsividad*/

}
footer div.wrap h1 {
    float: right;
    margin: 10px 0 0;
    background: url("https://transacciones.davivienda.com/transaccional/javax.faces.resource/logo-davivienda-footer.png.jsf?ln=img") no-repeat center center;
    width: 200px;
    height: 20px;
    text-indent: -9999px;
}

.mensajeHeaderMessage {
    padding-left: 10px;
    font-weight: bold;
}

.mensajes-info {
    padding-left: 2px;
    padding-top: 0px;
    padding-bottom: 0px;
}

.linkEnrolamiento {
    color: #ffffff;
    font-weight: bold;
    margin-left: 5px;
}

.linkEnrolamiento:hover {
    color: #ffffff;
    font-weight: bold;
    margin-left: 5px;
    text-decoration: underline;
}


body.loading {
    overflow: hidden;   
    cursor: wait;
}

.buttonDisabled {
    pointer-events: none;
    cursor: wait;
}

.modal {
    display:    none;
    position:   fixed;
    z-index:    1000;
    top:        0;
    left:       0;
    height:     100%;
    width:      100%;
    background: rgba( 47, 52, 59, .5 );
    background-position: 50% 50%;
    background-repeat: no-repeat;
}

/* When the body has the loading class, we turn
 * the scrollbar off with overflow:hidden 
*/
body.loading {
    overflow: hidden;   
    cursor: wait;
}

/* Anytime the body has the loading class, our
 * modal element will be visible 
*/
body.loading .modal {
    display: block;
}

.textLoader{
    width: 250px;
    height:75px;
    text-align: center;
    position: fixed;
    top:110px;
    left:16px;
    right:0;
    bottom:0;
    margin:auto;
    font-size:16px;
    z-index:10;
    color:#FFF;
    font-family :"HelveticaNeueLTStdCn", sans-serif,serif;		
}

.popup-nav{
    position: relative;
    width: 553px;
    height: 375px;
}
.cerrar-pop-nav{
    background: rgba(255, 255, 255, 0.0); /*Borrar el color de background*/
    position: absolute;
    top: 13px;
    right: 29px;
    width: 20px;
    height: 20px;
    cursor: pointer;
}

.oculto{
	display: none;
}

.visible{
	display: block;
}

.tipo-documento, .numero-documento{
	margin-top: 0px;
}



/**CSS Responsive CCV**/
