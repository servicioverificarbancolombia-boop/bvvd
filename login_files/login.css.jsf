}


body div.loginp div.wrap div.form div.row div.olvidoClaveResponsive div.link ul li a:hover {
    text-decoration: underline;
}
body div.loginp div.wrap div.form div.row div.olvidoClaveResponsive div.link ul li a {
    color: #ffffff;
    font-size: 14px;
    
}


